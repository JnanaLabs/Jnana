# ─────────────────────────────────────────────
# Supabase
# Get these from: Supabase Dashboard → Project Settings → API
# ─────────────────────────────────────────────
# Project URL  (e.g. https://abcdefgh.supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/public key  — safe for read-only frontend use
SUPABASE_ANON_KEY=your-anon-key

# Service role key  — used by backend/pipeline for writes (bypasses RLS)
# KEEP THIS SECRET — never expose in frontend or commit to git
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────
# Embedding Model
# "auto"   → picks provider based on available API keys (recommended)
# "openai" → force OpenAI text-embedding-3-small (dim=1536)
# "gemini" → force Gemini text-embedding-004 (dim=768)
# "local"  → force BAAI/bge-small-en-v1.5 (free, offline, dim=384)
#
# WARNING: Never mix embedding models in the same Supabase table.
# If you change this, drop the table and re-run ingest from scratch.
# ─────────────────────────────────────────────
EMBED_MODEL=auto

# ─────────────────────────────────────────────
# OpenAI  (optional — leave blank, Gemini will be used)
# Priority: OpenAI > Gemini > local
# ─────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────
# Gemini  (default fallback — free tier: 1M tokens/day)
# text-embedding-004 dim=768  |  gemini-1.5-flash for generation
# ─────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_EMBED_MODEL=models/text-embedding-004
GEMINI_CHAT_MODEL=gemini-1.5-flash

# ─────────────────────────────────────────────
# API Server
# ─────────────────────────────────────────────
PORT=8000
# Comma-separated allowed origins for CORS (use * for dev)
ALLOWED_ORIGINS=*
