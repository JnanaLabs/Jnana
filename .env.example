# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# Embedding model: "openai" or "local" (uses BAAI/bge-small-en, free)
EMBED_MODEL=openai

# OpenAI (required if EMBED_MODEL=openai or LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini

# Gemini (optional alternative LLM)
LLM_PROVIDER=openai
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
