# ─────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# ─────────────────────────────────────────
# Embedding Model
# "openai"  → uses OPENAI_EMBED_MODEL (needs OPENAI_API_KEY)
# "local"   → uses BAAI/bge-small-en-v1.5 (free, offline, dim=384)
# auto      → picks OpenAI if key present, else Gemini, else local
# ─────────────────────────────────────────
EMBED_MODEL=auto

# ─────────────────────────────────────────
# OpenAI (optional — leave blank to skip)
# If set, takes priority over Gemini for both embedding + generation
# ─────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# ─────────────────────────────────────────
# Gemini (fallback when OpenAI key is absent)
# Free tier: 1M tokens/day on gemini-1.5-flash
# Embeddings: models/text-embedding-004 (dim=768)
# ─────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_EMBED_MODEL=models/text-embedding-004
GEMINI_CHAT_MODEL=gemini-1.5-flash
